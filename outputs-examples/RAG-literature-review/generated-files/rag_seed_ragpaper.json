    {
      "source": "openalex",
      "id": "W3166846774",
      "openalex_id": "W3166846774",
      "title": "Learning How to Ask: Querying LMs with Mixtures of Soft Prompts",
      "authors": [
        "Guanghui Qin",
        "Jason Eisner"
      ],
      "author_details": [
        {
          "name": "Guanghui Qin",
          "orcid": "https://orcid.org/0000-0002-3009-8614",
