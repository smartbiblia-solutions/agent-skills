{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartbiblia.example/schemas/generate-agent-scaffold/output.schema.json",
  "title": "generate-agent-scaffold output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_name",
    "template",
    "summary",
    "directories",
    "files",
    "assumptions",
    "next_steps"
  ],
  "properties": {
    "agent_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "template": {
      "type": "string",
      "enum": ["minimal", "standard", "full"]
    },
    "topology": {
      "type": "string",
      "enum": [
        "DIRECT_CODE",
        "SINGLE",
        "PIPELINE",
        "FORK_JOIN",
        "CRITIC_LOOP",
        "HIERARCHICAL"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "decision_log": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_needed", "justification"],
      "properties": {
        "agent_needed": {
          "type": "boolean"
        },
        "simpler_alternative": {
          "type": ["string", "null"],
          "description": "Description of a simpler solution (e.g., script, single skill)"
        },
        "justification": {
          "type": "string"
        }
      }
    },
    "directories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/directory"
      }
    },
    "files": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/file"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skill_refs": {
      "type": "array",
      "description": "Structured list of all skill references extracted from the brief.",
      "items": {
        "$ref": "#/$defs/skill_ref"
      }
    }
  },
  "$defs": {
    "directory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "purpose", "required"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "^/"
          }
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "skill_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "type"],
      "properties": {
        "ref": {
          "type": "string",
          "description": "Normalized skill reference: bare kebab-case name for local refs, owner/repo[@version] for remote refs.",
          "pattern": "^([a-z][a-z0-9-]*|[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+(@[a-zA-Z0-9._/-]+)?)$"
        },
        "type": {
          "type": "string",
          "enum": ["local", "github"]
        },
        "source": {
          "type": "string",
          "description": "Original URL or string from the brief."
        },
        "version": {
          "type": ["string", "null"],
          "description": "Pinned version tag, branch, or SHA. Null if resolved to default branch."
        }
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "purpose", "required", "content"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "^/"
          }
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "content": {
          "type": "string"
        }
      }
    }
  }
}
