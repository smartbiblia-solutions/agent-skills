{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartbiblia.example/schemas/generate-agent-scaffold-gitagent/output.schema.json",
  "title": "generate-agent-scaffold-gitagent output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_name",
    "template",
    "gitagent_spec_version",
    "summary",
    "directories",
    "files",
    "assumptions",
    "next_steps"
  ],
  "properties": {
    "agent_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "template": {
      "type": "string",
      "enum": ["minimal", "standard", "full"]
    },
    "gitagent_spec_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
	"topology": {
	  "type": "string",
	  "enum": [
		"DIRECT_CODE",
		"SINGLE",
		"PIPELINE",
		"FORK_JOIN",
		"CRITIC_LOOP",
		"HIERARCHICAL"
	  ]
	},
    "summary": {
      "type": "string",
      "minLength": 1
    },
	"decision_log": {
	  "type": "object",
	  "additionalProperties": false,
	  "required": ["agent_needed", "justification"],
	  "properties": {
		"agent_needed": {
		  "type": "boolean"
		},
		"simpler_alternative": {
		  "type": ["string", "null"],
		  "description": "Description of a simpler solution (e.g., script, single skill)"
		},
		"justification": {
		  "type": "string"
		}
	  }
	},
    "directories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/directory"
      }
    },
    "files": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/file"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "directory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "purpose", "required"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "^/"
          }
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "purpose", "required", "content"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "^/"
          }
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "content": {
          "type": "string"
        }
      }
    }
  }
}
