{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Thesis metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document-type",
    "title",
    "subtitle",
    "author",
    "advisor",
    "jury_president",
    "reviewers",
    "committee_members",
    "defense_year",
    "language",
    "abstract_language",
    "degree_type",
    "discipline",
    "granting_institution",
    "co_tutelle_institutions",
    "doctoral_school",
    "partner_institutions",
    "abstract"
  ],
  "properties": {
    "document-type": {"type": "string", "enum": ["thesis", "dissertation"]},
    "title": {"type": "string"},
    "subtitle": {"type": "string"},
    "author": {"type": "string"},
    "advisor": {"type": "array", "items": {"type": "string"}},
    "jury_president": {"type": "array", "items": {"type": "string"}},
    "reviewers": {"type": "array", "items": {"type": "string"}},
    "committee_members": {"type": "array", "items": {"type": "string"}},
    "defense_year": {"type": "string"},
    "language": {"type": "string"},
    "abstract_language": {"type": "array", "items": {"type": "string"}},
    "degree_type": {"type": "string"},
    "discipline": {"type": "string"},
    "granting_institution": {"type": "string"},
    "co_tutelle_institutions": {"type": "array", "items": {"type": "string"}},
    "doctoral_school": {"type": "array", "items": {"type": "string"}},
    "partner_institutions": {"type": "array", "items": {"type": "string"}},
    "abstract": {"type": "string"}
  }
}
